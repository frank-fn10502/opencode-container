{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["ollama", "github-copilot"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://host.docker.internal:11434/v1"
      },
      "models": {
        "qwen3.5:9b": {
          "name": "qwen3.5:9b"
        },
        "qwen3:8b": {
          "name": "qwen3:8b"
        },
        "gemma4:e4b": {
          "name": "gemma4:e4b"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss:20b"
        }
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "websearch": "allow"
  },
  "model": "ollama/qwen3.5:9b",
  "small_model": "ollama/qwen3:8b"
}
