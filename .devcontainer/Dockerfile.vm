FROM localhost/opencode-dev-yuta:base

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        htop \
        iproute2 \
        lsof \
        net-tools \
        openssh-client \
        openssh-server \
        procps \
        rsync \
        tmux \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p \
        /run/sshd \
        /home/opencode/.cache \
        /home/opencode/.ssh \
    && chown -R opencode:opencode \
        /home/opencode/.cache \
        /home/opencode/.ssh

WORKDIR /workspace
