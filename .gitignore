# macOS
.DS_Store

# Editor / tooling
.vscode/

# OpenCode runtime artifacts should not be stored in this repository.
.devcontainer/state/
.devcontainer/config/node_modules/
.devcontainer/config/package.json
.devcontainer/config/package-lock.json
.devcontainer/config/bun.lock
.devcontainer/config/.gitignore

# Human-readable generated reports are kept locally.
opencode-output/*
!opencode-output/.gitkeep

.tmp/

# Local Docker image packages are distributed outside git.
.docker_imgs/*
!.docker_imgs/.gitkeep

# Company CA certificates can be collected or placed locally for admin builds.
admin/ca/*.crt

test_opencode/logs/
.opencode-dev-yuta/